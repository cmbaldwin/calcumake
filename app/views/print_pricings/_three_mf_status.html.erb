<% if print_pricing.three_mf_file.attached? || print_pricing.three_mf_import_status.present? %>
  <% status = print_pricing.three_mf_import_status || "pending" %>
  <% alert_class = three_mf_status_class(status) %>
  <% icon_class = three_mf_status_icon(status) %>

  <div class="alert <%= alert_class %> d-flex align-items-center" role="alert">
    <% if status == "processing" %>
      <div class="spinner-border spinner-border-sm me-2" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    <% else %>
      <i class="bi <%= icon_class %> me-2"></i>
    <% end %>

    <div class="flex-grow-1">
      <strong><%= t("print_pricing.three_mf.status.#{status}") %></strong>

      <% if status == "failed" && print_pricing.three_mf_import_error.present? %>
        <div class="mt-1">
          <%= print_pricing.three_mf_import_error %>
        </div>
      <% end %>

      <% if print_pricing.three_mf_file.attached? %>
        <div class="mt-1 text-muted small">
          <%= print_pricing.three_mf_file.filename %> (<%= number_to_human_size(print_pricing.three_mf_file.byte_size) %>)
        </div>
      <% end %>
    </div>

    <% if print_pricing.three_mf_file.attached? %>
      <%= link_to t("print_pricing.three_mf.download"),
          rails_blob_path(print_pricing.three_mf_file, disposition: "attachment"),
          class: "btn btn-sm btn-outline-secondary ms-2" %>
    <% end %>
  </div>
<% end %>
